{
  "rewrites": [
    { "source": "/report/:uuid", "destination": "/" },
    { "source": "/((?!assets/|_/backend/|logo\\.png|favicon\\.svg|icons\\.svg|robots\\.txt|security\\.txt|\\.well-known/).*)", "destination": "/" }
  ],
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "server.js",
      "framework": "node",
      "routePrefix": "/_/backend"
    }
  }
}
